# ── External APIs (required for full functionality) ──────────────────────────
ELEVENLABS_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3-flash-preview
OPENROUTER_REFERER=http://localhost:3000
OPENROUTER_TITLE=Meeting Assistant

# ── Storage / DB ──────────────────────────────────────────────────────────────
STORAGE_DIR=./storage
DATABASE_URL=sqlite+aiosqlite:///./meeting.db

# ── Networking / CORS ─────────────────────────────────────────────────────────
# Comma-separated list of permitted browser origins (scheme + host + port).
# Add every origin the frontend will be served from. Examples:
#   ALLOWED_ORIGIN=http://localhost:3001
#   ALLOWED_ORIGIN=http://localhost:3001,http://192.168.1.10:3001
ALLOWED_ORIGIN=http://localhost:3000
# Regex alternative (overrides ALLOWED_ORIGIN if non-empty).
# ALLOWED_ORIGIN_REGEX=^https?://(localhost|192\.168\.[0-9]+\.[0-9]+):[0-9]+$

# ── Auth / session ────────────────────────────────────────────────────────────
# CHANGE THIS in any non-throwaway deployment. Any random ≥32-char string.
SESSION_SECRET=dev-secret-change-me-in-prod-min-32-chars
SESSION_COOKIE_NAME=ma_session
# Same-site policy. "lax" works for same-site cross-port (localhost:3001 ↔
# localhost:8001). For cross-site (different hostnames) set "none" AND
# SESSION_COOKIE_SECURE=true (requires HTTPS).
SESSION_SAME_SITE=lax
SESSION_COOKIE_SECURE=false
SESSION_MAX_AGE_S=1209600

# ── Server bind ──────────────────────────────────────────────────────────────
# Consumed by the launch command, NOT by the app code:
#   uv run uvicorn app.main:app --host "$HOST" --port "$PORT"
HOST=0.0.0.0
PORT=8000
